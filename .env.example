# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Infura API key — get one free at https://app.infura.io
EXPO_PUBLIC_INFURA_KEY=your_infura_project_id_here

# Supabase — get from https://app.supabase.com
EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Pinata IPFS — get from https://app.pinata.cloud
EXPO_PUBLIC_PINATA_API_KEY=your_pinata_api_key_here
EXPO_PUBLIC_PINATA_SECRET=your_pinata_secret_here

# Block explorer API keys (optional — higher rate limits)
EXPO_PUBLIC_ETHERSCAN_API_KEY=your_etherscan_api_key_here
EXPO_PUBLIC_BSCSCAN_API_KEY=your_bscscan_api_key_here
EXPO_PUBLIC_POLYGONSCAN_API_KEY=your_polygonscan_api_key_here
